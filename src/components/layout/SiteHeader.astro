---
import { navigationLinks } from '../../data/navigation';

const baseURL = import.meta.env.BASE_URL;
---

<header class="site-header panel" data-site-header>
  <a class="brand" href={`${baseURL}#home`} aria-label="Gaurangkumar Patel — Home">
    <span class="brand-mark" aria-hidden="true">GP</span>

    <span class="brand-copy">
      <strong>Gaurangkumar Patel</strong>
      <small>Backend Engineering Portfolio</small>
    </span>
  </a>

  <button
    class="menu-button"
    type="button"
    aria-expanded="false"
    aria-controls="primary-navigation"
    aria-label="Open navigation menu"
    data-menu-button
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav
    id="primary-navigation"
    class="navigation"
    aria-label="Primary navigation"
    data-navigation
  >
    {
      navigationLinks.map((link) => (
        <a
            href={`${baseURL}${link.href}`}
            data-navigation-link
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="header-status">
    <span class="status-light" aria-hidden="true"></span>
    <span>London, UK</span>
  </div>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const menuButton = document.querySelector('[data-menu-button]');
  const navigation = document.querySelector('[data-navigation]');
  const navigationLinks = document.querySelectorAll<HTMLAnchorElement>('[data-navigation-link]',);

  const closeMenu = () => {
    menuButton?.setAttribute('aria-expanded', 'false');
    menuButton?.setAttribute('aria-label', 'Open navigation menu');
    navigation?.classList.remove('is-open');
  };

  menuButton?.addEventListener('click', () => {
    const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';

    menuButton.setAttribute('aria-expanded', String(!isExpanded));
    menuButton.setAttribute(
      'aria-label',
      isExpanded ? 'Open navigation menu' : 'Close navigation menu',
    );

    navigation?.classList.toggle('is-open');
  });

  navigationLinks.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenu();
    }
  });

  const sections = document.querySelectorAll('section[id]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) {
          return;
        }

        navigationLinks.forEach((link) => {
            const linkHash = new URL(link.href).hash;
            const isActive = linkHash === `#${entry.target.id}`;

          link.classList.toggle('is-active', isActive);

          if (isActive) {
            link.setAttribute('aria-current', 'page');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      });
    },
    {
      rootMargin: '-35% 0px -55% 0px',
      threshold: 0,
    },
  );

  sections.forEach((section) => observer.observe(section));

  const updateHeader = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 20);
  };

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>

<style>
  .panel {
    border: 1px solid var(--border);
    background:
      linear-gradient(
        145deg,
        rgba(45, 49, 52, 0.96),
        rgba(22, 24, 26, 0.97)
      );
    box-shadow:
      18px 18px 45px rgba(0, 0, 0, 0.45),
      -8px -8px 30px rgba(255, 255, 255, 0.025),
      inset 1px 1px 1px rgba(255, 255, 255, 0.08),
      inset -1px -1px 1px rgba(0, 0, 0, 0.8);
  }

  .site-header {
    position: sticky;
    z-index: 100;
    top: 16px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 30px;
    padding: 13px 16px;
    border-radius: 22px;
    transition:
      transform 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .site-header.is-scrolled {
    background:
      linear-gradient(
        145deg,
        rgba(38, 42, 45, 0.94),
        rgba(17, 19, 21, 0.96)
      );
    box-shadow:
      14px 14px 35px rgba(0, 0, 0, 0.55),
      inset 1px 1px 1px rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-mark {
    display: grid;
    width: 44px;
    height: 44px;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 14px;
    color: white;
    font-weight: 850;
    background: linear-gradient(145deg, #ff6565, #bd2929);
    box-shadow:
      5px 5px 12px rgba(0, 0, 0, 0.55),
      -3px -3px 10px rgba(255, 255, 255, 0.08),
      inset 2px 2px 3px rgba(255, 255, 255, 0.25);
  }

  .brand-copy strong,
  .brand-copy small {
    display: block;
  }

  .brand-copy small {
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.76rem;
  }

  .navigation {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }

  .navigation a {
    position: relative;
    padding: 10px 12px;
    border-radius: 11px;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 650;
    transition:
      color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease;
  }

  .navigation a:hover,
  .navigation a:focus-visible,
  .navigation a.is-active {
    color: white;
    background: rgba(255, 255, 255, 0.045);
    box-shadow: inset 2px 2px 6px rgba(0, 0, 0, 0.35);
  }

  .navigation a.is-active::after {
    position: absolute;
    right: 12px;
    bottom: 5px;
    left: 12px;
    height: 2px;
    border-radius: 999px;
    content: '';
    background: var(--accent);
    box-shadow: 0 0 8px rgba(239, 77, 77, 0.75);
  }

  .header-status {
    display: flex;
    align-items: center;
    gap: 9px;
    color: var(--muted);
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .status-light {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 12px var(--success);
  }

  .menu-button {
    display: none;
    width: 44px;
    height: 44px;
    cursor: pointer;
    border: 1px solid var(--border);
    border-radius: 13px;
    background: linear-gradient(145deg, #292d30, #17191b);
    box-shadow:
      5px 5px 12px rgba(0, 0, 0, 0.45),
      inset 1px 1px 1px rgba(255, 255, 255, 0.08);
  }

  .menu-button span {
    display: block;
    width: 19px;
    height: 2px;
    margin: 4px auto;
    border-radius: 999px;
    background: var(--text);
    transition:
      transform 180ms ease,
      opacity 180ms ease;
  }

  .menu-button[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .menu-button[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }

  .menu-button[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 1080px) {
    .site-header {
      grid-template-columns: auto auto;
      justify-content: space-between;
    }

    .menu-button {
      display: block;
    }

    .header-status {
      display: none;
    }

    .navigation {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      left: 0;
      display: none;
      align-items: stretch;
      padding: 12px;
      border: 1px solid var(--border);
      border-radius: 18px;
      background:
        linear-gradient(
          145deg,
          rgba(42, 46, 49, 0.98),
          rgba(18, 20, 22, 0.99)
        );
      box-shadow: 16px 16px 35px rgba(0, 0, 0, 0.55);
    }

    .navigation.is-open {
      display: grid;
    }

    .navigation a {
      padding: 13px 14px;
    }

    .navigation a.is-active::after {
      top: 10px;
      right: auto;
      bottom: 10px;
      left: 5px;
      width: 2px;
      height: auto;
    }
  }

  @media (max-width: 520px) {
    .site-header {
      top: 8px;
      padding: 10px;
    }

    .brand-copy strong {
      max-width: 180px;
      overflow: hidden;
      font-size: 0.9rem;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .brand-copy small {
      font-size: 0.66rem;
    }

    .brand-mark,
    .menu-button {
      width: 40px;
      height: 40px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .navigation a,
    .menu-button span {
      transition: none;
    }
  }
</style>