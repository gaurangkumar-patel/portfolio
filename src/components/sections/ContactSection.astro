---
import {
  confirmedEmail,
  contactLinks,
} from '../../data/contact';

import SectionHeader from '../ui/SectionHeader.astro';

const links = confirmedEmail
  ? [
      ...contactLinks,
      {
        label: 'Email',
        description: 'Send a direct message about a suitable opportunity.',
        url: `mailto:${confirmedEmail}`,
        type: 'email' as const,
        external: false,
      },
    ]
  : contactLinks;
---

<section
  id="contact"
  class="contact-section"
  aria-labelledby="contact-title"
>
  <SectionHeader
    id="contact-title"
    eyebrow="COMMUNICATION CONSOLE // OPEN CHANNEL"
    title="Let’s build dependable software together."
    description="Open to suitable PHP/Laravel backend and backend-heavy full-stack opportunities across London, hybrid and remote UK teams."
  />

  <div class="contact-layout">
    <div class="contact-console">
      <div class="console-header">
        <div class="console-lights" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <span>COMMUNICATION_CHANNEL.exe</span>
        <span class="power-light" aria-hidden="true"></span>
      </div>

      <div class="console-screen">
        <div class="screen-grid" aria-hidden="true"></div>
        <div class="scan-line" aria-hidden="true"></div>

        <p class="console-label">CONNECTION_STATUS.LOG</p>

        <div class="terminal-copy">
          <p><span>&gt;</span> Identity: Gaurangkumar Patel</p>
          <p><span>&gt;</span> Role: Backend Software Engineer</p>
          <p><span>&gt;</span> Location: London, UK</p>
          <p><span>&gt;</span> Focus: PHP / Laravel / REST APIs</p>
          <p><span>&gt;</span> Notice period: 4 weeks</p>
          <p class="success">
            <span>&gt;</span> Status: Open to suitable opportunities
          </p>
        </div>

        <div class="signal-display" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>

      <div class="console-controls" aria-hidden="true">
        <span></span>
        <span></span>
        <span class="active"></span>
      </div>
    </div>

    <div class="contact-content">
      <div class="availability-panel">
        <span class="availability-light" aria-hidden="true"></span>

        <div>
          <small>CURRENT AVAILABILITY</small>
          <strong>London · Hybrid · Remote UK</strong>
        </div>
      </div>

      <div class="contact-links">
        {
          links.map((link, index) => (
            <a
              class:list={[
                'contact-link',
                `contact-${link.type}`,
              ]}
              href={link.url}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noreferrer' : undefined}
              download={link.type === 'cv' ? true : undefined}
            >
              <span class="link-number">
                {String(index + 1).padStart(2, '0')}
              </span>

              <span class="link-copy">
                <strong>{link.label}</strong>
                <small>{link.description}</small>
              </span>

              <span class="link-arrow" aria-hidden="true">
                {link.external ? '↗' : '→'}
              </span>
            </a>
          ))
        }
      </div>

      <div class="contact-note">
        <span aria-hidden="true"></span>

        <p>
          Recruiters and engineering teams can connect through
          LinkedIn or review the public GitHub portfolio.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    margin-top: 30px;
    padding: clamp(40px, 7vw, 92px);
    border: 1px solid var(--border);
    border-radius: 32px;
    background:
      radial-gradient(
        circle at 12% 85%,
        rgba(121, 230, 167, 0.08),
        transparent 27rem
      ),
      linear-gradient(
        145deg,
        rgba(37, 41, 44, 0.84),
        rgba(15, 17, 19, 0.96)
      );
    box-shadow:
      18px 18px 45px rgba(0, 0, 0, 0.4),
      inset 1px 1px 1px rgba(255, 255, 255, 0.055);
  }

  .contact-layout {
    display: grid;
    grid-template-columns:
      minmax(340px, 0.85fr)
      minmax(0, 1.15fr);
    gap: clamp(24px, 4vw, 48px);
    align-items: center;
    margin-top: 48px;
  }

  .contact-console {
    min-width: 0;
    padding: 17px;
    border: 1px solid var(--border);
    border-radius: 27px;
    background:
      linear-gradient(
        145deg,
        rgba(47, 51, 54, 0.97),
        rgba(17, 19, 21, 0.99)
      );
    box-shadow:
      17px 17px 38px rgba(0, 0, 0, 0.46),
      inset 1px 1px 1px rgba(255, 255, 255, 0.075);
  }

  .console-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 3px 4px 14px;
    color: #798185;
    font-family: monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
  }

  .console-lights {
    display: flex;
    gap: 6px;
  }

  .console-lights span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #40464a;
    box-shadow:
      inset 2px 2px 3px rgba(0, 0, 0, 0.72);
  }

  .power-light,
  .availability-light {
    width: 9px;
    height: 9px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 11px var(--success);
  }

  .console-screen {
    position: relative;
    min-height: 430px;
    overflow: hidden;
    padding: 28px;
    border: 9px solid #101214;
    border-radius: 22px;
    background:
      radial-gradient(
        circle at center,
        #122219,
        #06100b 72%
      );
    box-shadow:
      inset 10px 10px 28px rgba(0, 0, 0, 0.9);
  }

  .screen-grid {
    position: absolute;
    inset: 0;
    opacity: 0.5;
    background:
      linear-gradient(
        rgba(121, 230, 167, 0.035) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        rgba(121, 230, 167, 0.035) 1px,
        transparent 1px
      );
    background-size: 24px 24px;
  }

  .console-label,
  .terminal-copy,
  .signal-display {
    position: relative;
    z-index: 2;
  }

  .console-label {
    margin: 0;
    color: #698b75;
    font-family: monospace;
    font-size: 0.65rem;
    letter-spacing: 0.14em;
  }

  .terminal-copy {
    margin-top: 26px;
    color: #91a89a;
    font-family: monospace;
    font-size: 0.78rem;
    line-height: 1.75;
  }

  .terminal-copy span,
  .terminal-copy .success {
    color: var(--success);
  }

  .signal-display {
    display: flex;
    height: 80px;
    align-items: flex-end;
    gap: 10px;
    margin-top: 50px;
  }

  .signal-display span {
    width: 11px;
    border-radius: 999px;
    background: var(--success);
    box-shadow: 0 0 10px rgba(121, 230, 167, 0.45);
  }

  .signal-display span:nth-child(1) {
    height: 20%;
  }

  .signal-display span:nth-child(2) {
    height: 38%;
  }

  .signal-display span:nth-child(3) {
    height: 58%;
  }

  .signal-display span:nth-child(4) {
    height: 78%;
  }

  .signal-display span:nth-child(5) {
    height: 100%;
  }

  .scan-line {
    position: absolute;
    z-index: 1;
    right: 0;
    left: 0;
    height: 2px;
    opacity: 0.24;
    background: var(--success);
    box-shadow: 0 0 17px var(--success);
    animation: scan 5s linear infinite;
  }

  .console-controls {
    display: flex;
    justify-content: flex-end;
    gap: 14px;
    padding: 14px 6px 1px;
  }

  .console-controls span {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #33383b;
    box-shadow:
      3px 3px 6px rgba(0, 0, 0, 0.65),
      inset 1px 1px 2px rgba(255, 255, 255, 0.07);
  }

  .console-controls .active {
    background: var(--success);
    box-shadow: 0 0 10px var(--success);
  }

  .contact-content {
    min-width: 0;
  }

  .availability-panel {
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 17px 19px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.2);
    box-shadow:
      inset 5px 5px 13px rgba(0, 0, 0, 0.36);
  }

  .availability-panel small,
  .availability-panel strong {
    display: block;
  }

  .availability-panel small {
    color: #777f83;
    font-family: monospace;
    font-size: 0.64rem;
    letter-spacing: 0.11em;
  }

  .availability-panel strong {
    margin-top: 5px;
  }

  .contact-links {
    display: grid;
    gap: 14px;
    margin-top: 20px;
  }

  .contact-link {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    min-width: 0;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 18px;
    background:
      linear-gradient(
        145deg,
        rgba(43, 47, 50, 0.95),
        rgba(18, 20, 22, 0.98)
      );
    box-shadow:
      10px 10px 24px rgba(0, 0, 0, 0.36),
      inset 1px 1px 1px rgba(255, 255, 255, 0.06);
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .contact-link:hover {
    transform: translateY(-3px);
    border-color: rgba(121, 230, 167, 0.2);
  }

  .link-number {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: 13px;
    color: var(--accent);
    font-family: monospace;
    font-size: 0.7rem;
    font-weight: 800;
    background: rgba(0, 0, 0, 0.26);
    box-shadow:
      inset 4px 4px 10px rgba(0, 0, 0, 0.5);
  }

  .link-copy {
    min-width: 0;
  }

  .link-copy strong,
  .link-copy small {
    display: block;
  }

  .link-copy small {
    margin-top: 6px;
    color: var(--muted);
    line-height: 1.5;
  }

  .link-arrow {
    color: var(--success);
    font-size: 1.1rem;
  }

  .contact-cv {
    border-color: rgba(239, 77, 77, 0.16);
  }

  .contact-cv .link-arrow {
    color: var(--accent);
  }

  .contact-note {
    display: flex;
    gap: 11px;
    margin-top: 20px;
    padding: 14px;
    border: 1px solid var(--border);
    border-radius: 13px;
    background: rgba(0, 0, 0, 0.15);
  }

  .contact-note > span {
    width: 8px;
    height: 8px;
    flex: 0 0 auto;
    margin-top: 5px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 9px var(--success);
  }

  .contact-note p {
    margin: 0;
    color: var(--muted);
    font-size: 0.75rem;
    line-height: 1.55;
  }

  @keyframes scan {
    from {
      top: 7%;
    }

    to {
      top: 93%;
    }
  }

  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 600px) {
    .contact-section {
      padding: 36px 18px;
    }

    .console-screen {
      min-height: 390px;
      padding: 20px;
    }

    .contact-link {
      grid-template-columns: 40px minmax(0, 1fr) auto;
      gap: 12px;
      padding: 17px 15px;
    }

    .link-number {
      width: 38px;
      height: 38px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scan-line {
      animation: none;
    }

    .contact-link {
      transition: none;
    }

    .contact-link:hover {
      transform: none;
    }
  }
</style>