---
import { Image } from 'astro:assets';
import profilePhoto from '../../assets/profile/gaurangkumar-patel-profile.webp';
import { profile } from '../../data/profile';
---

<section
  class="personal-intro"
  aria-labelledby="personal-intro-title"
  data-personal-intro
>
  <div class="portrait-console">
    <div class="console-header">
      <div class="console-lights" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>

      <span>ENGINEER_IDENTITY.exe</span>
      <span class="power-light" aria-hidden="true"></span>
    </div>

    <div class="portrait-screen">
      <Image
        class="profile-photo"
        src={profilePhoto}
        alt="Professional portrait of Gaurangkumar Patel"
        widths={[480, 720, 960]}
        sizes="(max-width: 900px) 100vw, 42vw"
        format="webp"
        loading="eager"
      />

      <div class="portrait-overlay" aria-hidden="true"></div>
      <div class="scan-line" aria-hidden="true"></div>

      <div class="identity-label">
        <span>IDENTITY VERIFIED</span>
        <strong>GP // BACKEND ENGINEER</strong>
      </div>
    </div>

    <div class="console-controls" aria-hidden="true">
      <span></span>
      <span></span>
      <span class="active"></span>
    </div>
  </div>

  <div class="intro-content">
    <p class="eyebrow">
      PERSONAL INTRODUCTION // SYSTEM ONLINE
    </p>

    <div class="intro-sequence" aria-labelledby="personal-intro-title">
      <p class="intro-line line-one">Hi, I’m</p>

      <h2 id="personal-intro-title" class="intro-line line-two">
        {profile.name}.
      </h2>

      <p class="role-line intro-line line-three">
        {profile.title}
      </p>

      <p class="intro-description intro-line line-four">
        I build maintainable backend applications, REST APIs and
        database-driven systems using PHP, Laravel and modern
        engineering practices.
      </p>
    </div>

    <div class="intro-stack intro-line line-five">
      <span>PHP</span>
      <span>Laravel</span>
      <span>REST APIs</span>
      <span>MySQL</span>
      <span>Redis</span>
    </div>

    <div class="intro-actions intro-line line-six">
      <a href="#projects" class="primary-action">
        Explore my work
      </a>

      <button type="button" class="replay-button" data-replay-intro>
        Replay introduction
      </button>
    </div>

    <div class="availability">
      <span aria-hidden="true"></span>
      London-based backend engineer
    </div>
  </div>
</section>

<script>
  const sections = document.querySelectorAll<HTMLElement>(
    '[data-personal-intro]',
  );

  sections.forEach((section) => {
    const replayButton =
      section.querySelector<HTMLButtonElement>(
        '[data-replay-intro]',
      );

    const playIntroduction = () => {
      section.classList.remove('is-playing');

      void section.offsetWidth;

      section.classList.add('is-playing');
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const entry = entries[0];

        if (!entry?.isIntersecting) {
          return;
        }

        playIntroduction();
        observer.disconnect();
      },
      {
        threshold: 0.3,
      },
    );

    observer.observe(section);
    replayButton?.addEventListener('click', playIntroduction);
  });
</script>

<style>
  .personal-intro {
    display: grid;
    grid-template-columns: minmax(340px, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(28px, 5vw, 70px);
    align-items: center;
    margin-top: 30px;
    padding: clamp(32px, 6vw, 78px);
    border: 1px solid var(--border);
    border-radius: 32px;
    background:
      radial-gradient(
        circle at 12% 50%,
        rgba(239, 77, 77, 0.09),
        transparent 27rem
      ),
      linear-gradient(
        145deg,
        rgba(37, 41, 44, 0.86),
        rgba(15, 17, 19, 0.96)
      );
    box-shadow:
      18px 18px 45px rgba(0, 0, 0, 0.4),
      inset 1px 1px 1px rgba(255, 255, 255, 0.055);
  }

  .portrait-console {
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 27px;
    background:
      linear-gradient(
        145deg,
        rgba(47, 51, 54, 0.97),
        rgba(17, 19, 21, 0.99)
      );
    box-shadow:
      17px 17px 38px rgba(0, 0, 0, 0.46),
      inset 1px 1px 1px rgba(255, 255, 255, 0.075);
    transform: perspective(1100px) rotateY(2deg) rotateX(1deg);
  }

  .console-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 3px 4px 14px;
    color: #798185;
    font-family: monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
  }

  .console-lights {
    display: flex;
    gap: 6px;
  }

  .console-lights span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #40464a;
    box-shadow: inset 2px 2px 3px rgba(0, 0, 0, 0.72);
  }

  .power-light {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 11px var(--success);
  }

  .portrait-screen {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border: 9px solid #101214;
    border-radius: 22px;
    background: #07100b;
    box-shadow: inset 10px 10px 28px rgba(0, 0, 0, 0.9);
  }

  :global(.profile-photo) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 1.2s ease,
      filter 1.2s ease;
  }

  .portrait-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgba(4, 8, 6, 0.88),
        transparent 45%
      ),
      linear-gradient(
        110deg,
        rgba(239, 77, 77, 0.11),
        transparent 42%
      );
    pointer-events: none;
  }

  .identity-label {
    position: absolute;
    right: 22px;
    bottom: 20px;
    left: 22px;
  }

  .identity-label span,
  .identity-label strong {
    display: block;
  }

  .identity-label span {
    color: var(--success);
    font-family: monospace;
    font-size: 0.61rem;
    font-weight: 800;
    letter-spacing: 0.15em;
  }

  .identity-label strong {
    margin-top: 7px;
    font-size: 0.9rem;
  }

  .scan-line {
    position: absolute;
    z-index: 2;
    right: 0;
    left: 0;
    height: 2px;
    opacity: 0;
    background: var(--success);
    box-shadow: 0 0 18px var(--success);
  }

  .console-controls {
    display: flex;
    justify-content: flex-end;
    gap: 14px;
    padding: 14px 6px 1px;
  }

  .console-controls span {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #33383b;
    box-shadow:
      3px 3px 6px rgba(0, 0, 0, 0.65),
      inset 1px 1px 2px rgba(255, 255, 255, 0.07);
  }

  .console-controls .active {
    background: var(--success);
    box-shadow: 0 0 10px var(--success);
  }

  .eyebrow {
    margin: 0 0 24px;
    color: var(--accent);
    font-family: monospace;
    font-size: 0.73rem;
    font-weight: 800;
    letter-spacing: 0.16em;
  }

  .intro-line {
    opacity: 0;
    transform: translateY(22px);
  }

  .intro-sequence p,
  .intro-sequence h2 {
    margin: 0;
  }

  .line-one {
    color: var(--muted);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
  }

  .line-two {
    margin-top: 7px !important;
    font-size: clamp(3.2rem, 7vw, 7.2rem);
    line-height: 0.94;
    letter-spacing: -0.065em;
  }

  .role-line {
    margin-top: 18px !important;
    color: var(--success);
    font-family: monospace;
    font-size: clamp(0.9rem, 1.5vw, 1.15rem);
    font-weight: 750;
    letter-spacing: 0.06em;
  }

  .intro-description {
    max-width: 760px;
    margin-top: 28px !important;
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.78;
  }

  .intro-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 27px;
  }

  .intro-stack span {
    padding: 8px 11px;
    border: 1px solid rgba(121, 230, 167, 0.12);
    border-radius: 9px;
    color: #b6d2c0;
    font-family: monospace;
    font-size: 0.68rem;
    background: rgba(5, 14, 9, 0.33);
  }

  .intro-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 13px;
    margin-top: 31px;
  }

  .primary-action,
  .replay-button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 13px;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 750;
  }

  .primary-action {
    color: white;
    background: linear-gradient(145deg, #ff5e5e, #c82f2f);
    box-shadow:
      7px 7px 16px rgba(0, 0, 0, 0.45),
      inset 1px 1px 2px rgba(255, 255, 255, 0.3);
  }

  .replay-button {
    cursor: pointer;
    color: var(--muted);
    border: 1px solid var(--border);
    background: linear-gradient(145deg, #2a2e31, #181a1c);
    box-shadow:
      6px 6px 14px rgba(0, 0, 0, 0.4),
      inset 1px 1px 1px rgba(255, 255, 255, 0.07);
  }

  .availability {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 28px;
    color: #8b9397;
    font-size: 0.77rem;
  }

  .availability span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 10px var(--success);
  }

  .is-playing .intro-line {
    animation: reveal-line 650ms ease forwards;
  }

  .is-playing .line-one {
    animation-delay: 100ms;
  }

  .is-playing .line-two {
    animation-delay: 260ms;
  }

  .is-playing .line-three {
    animation-delay: 430ms;
  }

  .is-playing .line-four {
    animation-delay: 600ms;
  }

  .is-playing .line-five {
    animation-delay: 760ms;
  }

  .is-playing .line-six {
    animation-delay: 900ms;
  }

  .is-playing :global(.profile-photo) {
    transform: scale(1.035);
    filter: saturate(1.04) contrast(1.02);
  }

  .is-playing .scan-line {
    animation: scan 2.4s ease 1;
  }

  @keyframes reveal-line {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scan {
    0% {
      top: 4%;
      opacity: 0;
    }

    15% {
      opacity: 0.35;
    }

    85% {
      opacity: 0.35;
    }

    100% {
      top: 94%;
      opacity: 0;
    }
  }

  @media (max-width: 900px) {
    .personal-intro {
      grid-template-columns: 1fr;
    }

    .portrait-console {
      max-width: 620px;
      transform: none;
    }
  }

  @media (max-width: 600px) {
    .personal-intro {
      padding: 36px 20px;
    }

    .line-two {
      font-size: clamp(3rem, 15vw, 5rem);
    }

    .intro-actions {
      display: grid;
    }

    .primary-action,
    .replay-button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-line {
      opacity: 1;
      transform: none;
    }

    :global(.profile-photo) {
      transition: none;
    }

    .is-playing .intro-line,
    .is-playing .scan-line {
      animation: none;
    }
  }
</style>