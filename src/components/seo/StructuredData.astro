---
interface StructuredDataRecord {
  [key: string]: unknown;
}

interface Props {
  data?:
    | StructuredDataRecord
    | StructuredDataRecord[];
}

const { data } = Astro.props;

const records = data
  ? Array.isArray(data)
    ? data
    : [data]
  : [];

const serialiseStructuredData = (
  record: StructuredDataRecord,
): string => {
  return JSON.stringify(record).replace(
    /</g,
    '\\u003c',
  );
};
---

{
  records.map((record) => (
    <script
      type="application/ld+json"
      is:inline
      set:html={serialiseStructuredData(record)}
    />
  ))
}