---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
  description?: string;
}

const {
  id,
  eyebrow,
  title,
  description,
} = Astro.props;
---

<header class="section-header">
  <p>{eyebrow}</p>
  <h2 id={id}>{title}</h2>

  {
    description && (
      <div class="section-description">
        {description}
      </div>
    )
  }
</header>

<style>
  .section-header {
    max-width: 820px;
  }

  .section-header p {
    margin: 0 0 14px;
    color: var(--accent);
    font-family: monospace;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.17em;
  }

  .section-header h2 {
    margin: 0;
    font-size: clamp(2.8rem, 6vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  .section-description {
    max-width: 700px;
    margin-top: 22px;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }
</style>