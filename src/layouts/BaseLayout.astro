---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Gaurangkumar Patel | Backend Software Engineer',
  description = 'Backend Software Engineer specialising in PHP, Laravel, REST APIs and database-driven web applications.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const faviconURL = `${import.meta.env.BASE_URL}favicon.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={faviconURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#111315" />
  </head>

  <body>
    <a class="skip-link" href="#main-content">
      Skip to main content
    </a>
    <slot />
  </body>
  <style is:global>
    .skip-link {
      position: fixed;
      z-index: 9999;
      top: 12px;
      left: 12px;
      padding: 12px 16px;
      border-radius: 10px;
      color: #ffffff;
      font-weight: 700;
      background: var(--accent);
      transform: translateY(-160%);
      transition: transform 160ms ease;
    }

    .skip-link:focus {
      transform: translateY(0);
    }

    :focus-visible {
      outline: 3px solid rgba(121, 230, 167, 0.8);
      outline-offset: 4px;
    }

    section[id] {
      scroll-margin-top: 115px;
    }
  </style>
</html>