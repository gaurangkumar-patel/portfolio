---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';

import {
  allProjects,
  type Project,
  type ProjectCategory,
} from '../../data/projects';
import {
  siteMetadata,
} from '../../data/seo';

export function getStaticPaths() {
  return allProjects.map((project) => ({
    params: {
      slug: project.slug,
    },
    props: {
      project,
    },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

const baseURL = import.meta.env.BASE_URL;
const projectsURL = `${baseURL}#projects`;

const categoryLabels: Record<ProjectCategory, string> = {
  public: 'Open Project',
  product: 'Product Work',
  commercial: 'Commercial Experience',
};

const categoryLabel = categoryLabels[project.category];

const pageTitle =
  `${project.title} | Engineering Case Study | Gaurangkumar Patel`;

const pageDescription =
  `${project.summary} Technologies include ${project.technologies
    .slice(0, 5)
    .join(', ')}.`;

const caseStudyURL = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url,
);

const homepageURL = new URL(
  import.meta.env.BASE_URL,
  Astro.site ?? Astro.url,
);

const repositoryURL = project.links.find(
  (link) => link.type === 'repository',
)?.url;

const liveDemoURL = project.links.find(
  (link) => link.type === 'demo',
)?.url;

const projectStructuredData = {
  '@context': 'https://schema.org',

  '@type':
    project.visibility === 'public-repository'
      ? 'SoftwareSourceCode'
      : 'CreativeWork',

  name: project.title,

  description: project.summary,

  url: caseStudyURL.href,

  creator: {
    '@type': 'Person',
    '@id': `${homepageURL.href}#person`,
    name: 'Gaurangkumar Patel',
    url: homepageURL.href,
  },

  keywords: project.technologies.join(', '),

  ...(repositoryURL
    ? {
        codeRepository: repositoryURL,
      }
    : {}),

  ...(liveDemoURL
    ? {
        sameAs: [liveDemoURL],
      }
    : {}),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
  imageAlt={`${project.title} engineering case study by Gaurangkumar Patel`}
  structuredData={projectStructuredData}
>
  <div class="page-shell">
    <SiteHeader />

    <main id="main-content">
      <a class="back-link" href={projectsURL}>
        <span aria-hidden="true">←</span>
        Back to selected projects
      </a>

      <article
        class:list={[
          'case-study',
          `case-study-${project.category}`,
        ]}
      >
        <header class="case-study-hero">
          <div class="hero-content">
            <div class="hero-topline">
              <span class="category-badge">
                <span
                  class="category-light"
                  aria-hidden="true"
                ></span>

                {categoryLabel}
              </span>

              <span class="status-label">
                {project.statusLabel}
              </span>
            </div>

            <p class="case-eyebrow">
              PROJECT CASE STUDY // {project.domain}
            </p>

            <h1>{project.title}</h1>

            {
              project.shortTitle && (
                <p class="short-title">
                  {project.shortTitle}
                </p>
              )
            }

            {
              project.organisation && (
                <p class="organisation">
                  {project.organisation}
                </p>
              )
            }

            <p class="hero-summary">
              {project.summary}
            </p>

            <div
              class="technology-list"
              aria-label={`${project.title} technologies`}
            >
              {
                project.technologies.map((technology) => (
                  <span>{technology}</span>
                ))
              }
            </div>

            <div class="hero-actions">
              {
                project.links.map((link) => (
                  <a
                    class:list={[
                      'project-action',
                      `action-${link.type}`,
                    ]}
                    href={link.url}
                    target="_blank"
                    rel="noreferrer"
                  >
                    {link.label}
                    <span aria-hidden="true">↗</span>
                  </a>
                ))
              }

              <a
                class="project-action action-back"
                href={projectsURL}
              >
                Portfolio projects
              </a>
            </div>
          </div>

          <div
            class="project-console"
            aria-label={`${project.title} visual project summary`}
          >
            <div class="console-header">
              <div class="console-lights" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>

              <span>PROJECT_PROFILE.exe</span>
              <span class="power-light"></span>
            </div>

            <div class="console-screen">
              <div class="screen-grid"></div>
              <div class="scan-line"></div>

              <p class="console-label">
                SYSTEM RECORD
              </p>

              <div class="console-copy">
                <p>
                  <span>&gt;</span>
                  PROJECT: {project.title}
                </p>

                <p>
                  <span>&gt;</span>
                  CATEGORY: {categoryLabel}
                </p>

                <p>
                  <span>&gt;</span>
                  DOMAIN: {project.domain}
                </p>

                <p>
                  <span>&gt;</span>
                  VISIBILITY:
                  {
                    project.visibility ===
                    'public-repository'
                      ? ' PUBLIC'
                      : ' SUMMARY ONLY'
                  }
                </p>

                <p class="console-success">
                  <span>&gt;</span>
                  STATUS: {project.statusLabel}
                </p>
              </div>

              <div class="system-core" aria-hidden="true">
                <div class="core-ring core-ring-one"></div>
                <div class="core-ring core-ring-two"></div>

                <div class="core-centre">
                  {String(project.displayOrder).padStart(2, '0')}
                </div>
              </div>
            </div>

            <div class="console-controls">
              <span></span>
              <span></span>
              <span class="active"></span>
            </div>
          </div>
        </header>

        <section
          class="case-section overview-section"
          aria-labelledby="overview-title"
        >
          <div class="section-label">
            <span>01</span>

            <div>
              <p>ENGINEERING OVERVIEW</p>
              <h2 id="overview-title">
                Challenge and contribution
              </h2>
            </div>
          </div>

          <div class="overview-grid">
            <article class="information-card">
              <p class="card-label">CHALLENGE</p>
              <div>{project.challenge}</div>
            </article>

            <article class="information-card">
              <p class="card-label">CONTRIBUTION</p>
              <div>{project.contribution}</div>
            </article>
          </div>
        </section>

        <section
          class="case-section"
          aria-labelledby="delivery-title"
        >
          <div class="section-label">
            <span>02</span>

            <div>
              <p>IMPLEMENTATION RECORD</p>
              <h2 id="delivery-title">
                {
                  project.category === 'commercial'
                    ? 'Commercial engineering contribution'
                    : 'Implemented and delivered'
                }
              </h2>
            </div>
          </div>

          <div class="delivery-panel">
            <ul>
              {
                project.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))
              }
            </ul>
          </div>
        </section>

        {
          project.plannedWork.length > 0 && (
            <section
              class="case-section"
              aria-labelledby="planned-title"
            >
              <div class="section-label">
                <span>03</span>

                <div>
                  <p>FUTURE ROADMAP</p>
                  <h2 id="planned-title">
                    Planned improvements
                  </h2>
                </div>
              </div>

              <div class="planned-grid">
                {
                  project.plannedWork.map(
                    (plannedItem, index) => (
                      <article class="planned-card">
                        <span>
                          {String(index + 1).padStart(2, '0')}
                        </span>

                        <p>{plannedItem}</p>
                      </article>
                    ),
                  )
                }
              </div>
            </section>
          )
        }

        {
          project.sourceCodeNotice && (
            <aside class="confidentiality-panel">
              <span
                class="notice-light"
                aria-hidden="true"
              ></span>

              <div>
                <p>VISIBILITY AND OWNERSHIP</p>
                <strong>{project.sourceCodeNotice}</strong>
              </div>
            </aside>
          )
        }

        <footer class="case-footer">
          <div>
            <p>END OF PROJECT RECORD</p>
            <strong>
              Explore more engineering work
            </strong>
          </div>

          <a href={projectsURL}>
            View all projects
            <span aria-hidden="true">→</span>
          </a>
        </footer>
      </article>
    </main>
  </div>
</BaseLayout>

<style>
  .page-shell {
    width: min(1440px, calc(100% - 40px));
    margin: 0 auto;
    padding: 24px 0 70px;
  }

  main {
    padding-top: 30px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 20px;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .back-link:hover {
    color: white;
  }

  .case-study {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 32px;
    background:
      radial-gradient(
        circle at 90% 7%,
        rgba(121, 230, 167, 0.08),
        transparent 28rem
      ),
      linear-gradient(
        145deg,
        rgba(37, 41, 44, 0.86),
        rgba(15, 17, 19, 0.97)
      );
    box-shadow:
      20px 20px 50px rgba(0, 0, 0, 0.42),
      inset 1px 1px 1px
        rgba(255, 255, 255, 0.055);
  }

  .case-study-product {
    background:
      radial-gradient(
        circle at 90% 7%,
        rgba(239, 77, 77, 0.09),
        transparent 28rem
      ),
      linear-gradient(
        145deg,
        rgba(37, 41, 44, 0.86),
        rgba(15, 17, 19, 0.97)
      );
  }

  .case-study-commercial {
    background:
      radial-gradient(
        circle at 90% 7%,
        rgba(121, 174, 230, 0.09),
        transparent 28rem
      ),
      linear-gradient(
        145deg,
        rgba(37, 41, 44, 0.86),
        rgba(15, 17, 19, 0.97)
      );
  }

  .case-study-hero {
    display: grid;
    grid-template-columns:
      minmax(0, 1.08fr)
      minmax(420px, 0.92fr);
    gap: 32px;
    padding: clamp(32px, 6vw, 78px);
    border-bottom: 1px solid var(--border);
  }

  .hero-content {
    align-self: center;
  }

  .hero-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 11px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    font-family: monospace;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(0, 0, 0, 0.18);
  }

  .category-light,
  .power-light,
  .notice-light {
    width: 8px;
    height: 8px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 10px var(--success);
  }

  .case-study-product .category-light {
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
  }

  .case-study-commercial .category-light {
    background: #79aee6;
    box-shadow: 0 0 10px #79aee6;
  }

  .status-label {
    color: #828a8e;
    font-family: monospace;
    font-size: 0.67rem;
    text-align: right;
  }

  .case-eyebrow {
    margin: 38px 0 0;
    color: var(--accent);
    font-family: monospace;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 850px;
    margin: 16px 0 0;
    font-size: clamp(3.2rem, 7vw, 7.6rem);
    line-height: 0.94;
    letter-spacing: -0.065em;
  }

  .short-title {
    margin: 15px 0 0;
    color: #a4aaad;
    font-size: 1rem;
  }

  .organisation {
    margin: 14px 0 0;
    color: var(--accent);
    font-weight: 750;
  }

  .hero-summary {
    max-width: 790px;
    margin: 28px 0 0;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .technology-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 27px;
  }

  .technology-list span {
    padding: 8px 10px;
    border: 1px solid
      rgba(121, 230, 167, 0.12);
    border-radius: 9px;
    color: #b6d2c0;
    font-family: monospace;
    font-size: 0.68rem;
    background: rgba(5, 14, 9, 0.33);
    box-shadow:
      inset 2px 2px 5px
        rgba(0, 0, 0, 0.4);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 11px;
    margin-top: 30px;
  }

  .project-action {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 0 16px;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--muted);
    font-size: 0.77rem;
    font-weight: 750;
    background:
      linear-gradient(145deg, #292d30, #17191b);
    box-shadow:
      5px 5px 12px rgba(0, 0, 0, 0.42),
      inset 1px 1px 1px
        rgba(255, 255, 255, 0.07);
  }

  .action-demo {
    color: white;
    background:
      linear-gradient(145deg, #ff5e5e, #c82f2f);
  }

  .project-console {
    align-self: center;
    padding: 18px;
    border: 1px solid var(--border);
    border-radius: 27px;
    background:
      linear-gradient(
        145deg,
        rgba(44, 48, 51, 0.97),
        rgba(17, 19, 21, 0.98)
      );
    box-shadow:
      17px 17px 38px rgba(0, 0, 0, 0.45),
      inset 1px 1px 1px
        rgba(255, 255, 255, 0.075);
    transform:
      perspective(1100px)
      rotateY(-2deg)
      rotateX(1deg);
  }

  .console-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 3px 4px 15px;
    color: #798185;
    font-family: monospace;
    font-size: 0.64rem;
    letter-spacing: 0.1em;
  }

  .console-lights {
    display: flex;
    gap: 6px;
  }

  .console-lights span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #40464a;
    box-shadow:
      inset 2px 2px 3px
        rgba(0, 0, 0, 0.72);
  }

  .console-screen {
    position: relative;
    min-height: 500px;
    overflow: hidden;
    padding: 28px;
    border: 10px solid #101214;
    border-radius: 22px;
    background:
      radial-gradient(
        circle at center,
        #122219,
        #06100b 72%
      );
    box-shadow:
      inset 10px 10px 28px
        rgba(0, 0, 0, 0.9);
  }

  .screen-grid {
    position: absolute;
    inset: 0;
    opacity: 0.45;
    background:
      linear-gradient(
        rgba(121, 230, 167, 0.035) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        rgba(121, 230, 167, 0.035) 1px,
        transparent 1px
      );
    background-size: 25px 25px;
  }

  .console-label,
  .console-copy {
    position: relative;
    z-index: 2;
  }

  .console-label {
    margin: 0;
    color: #698b75;
    font-family: monospace;
    font-size: 0.65rem;
    letter-spacing: 0.14em;
  }

  .console-copy {
    margin-top: 24px;
    color: #91a89a;
    font-family: monospace;
    font-size: 0.78rem;
    line-height: 1.75;
  }

  .console-copy span,
  .console-success {
    color: var(--success);
  }

  .scan-line {
    position: absolute;
    z-index: 1;
    top: 8%;
    right: 0;
    left: 0;
    height: 2px;
    opacity: 0.3;
    background: var(--success);
    box-shadow: 0 0 18px var(--success);
    animation: scan 5s linear infinite;
  }

  .system-core {
    position: absolute;
    right: 34px;
    bottom: 40px;
    display: grid;
    width: 190px;
    height: 190px;
    place-items: center;
  }

  .core-ring {
    position: absolute;
    border: 1px solid
      rgba(121, 230, 167, 0.3);
    border-radius: 50%;
  }

  .core-ring-one {
    width: 155px;
    height: 155px;
  }

  .core-ring-two {
    width: 185px;
    height: 95px;
    transform: rotate(35deg);
  }

  .core-centre {
    display: grid;
    width: 70px;
    height: 70px;
    place-items: center;
    border-radius: 50%;
    color: #0b1510;
    font-family: monospace;
    font-weight: 900;
    background: var(--success);
    box-shadow:
      0 0 35px
        rgba(121, 230, 167, 0.4),
      inset 5px 5px 10px
        rgba(255, 255, 255, 0.35);
  }

  .console-controls {
    display: flex;
    justify-content: flex-end;
    gap: 17px;
    padding: 17px 8px 2px;
  }

  .console-controls span {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #33383b;
    box-shadow:
      3px 3px 6px rgba(0, 0, 0, 0.65),
      inset 1px 1px 2px
        rgba(255, 255, 255, 0.07);
  }

  .console-controls .active {
    background: var(--success);
    box-shadow: 0 0 10px var(--success);
  }

  .case-section {
    padding: clamp(38px, 6vw, 72px);
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .section-label > span {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: 15px;
    color: var(--accent);
    font-family: monospace;
    font-size: 0.7rem;
    font-weight: 800;
    background: rgba(0, 0, 0, 0.25);
    box-shadow:
      inset 4px 4px 10px
        rgba(0, 0, 0, 0.5);
  }

  .section-label p {
    margin: 0 0 9px;
    color: var(--accent);
    font-family: monospace;
    font-size: 0.67rem;
    font-weight: 800;
    letter-spacing: 0.13em;
  }

  .section-label h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.8rem);
    letter-spacing: -0.05em;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 36px;
  }

  .information-card,
  .delivery-panel,
  .planned-card {
    border: 1px solid var(--border);
    border-radius: 22px;
    background:
      linear-gradient(
        145deg,
        rgba(42, 46, 49, 0.94),
        rgba(18, 20, 22, 0.98)
      );
    box-shadow:
      13px 13px 30px rgba(0, 0, 0, 0.38),
      inset 1px 1px 1px
        rgba(255, 255, 255, 0.06);
  }

  .information-card {
    padding: 30px;
  }

  .card-label {
    margin: 0 0 18px;
    color: var(--success);
    font-family: monospace;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.13em;
  }

  .information-card > div {
    color: var(--muted);
    line-height: 1.75;
  }

  .delivery-panel {
    margin-top: 36px;
    padding: clamp(25px, 4vw, 42px);
  }

  .delivery-panel ul {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 17px 32px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .delivery-panel li {
    position: relative;
    padding-left: 23px;
    color: var(--muted);
    line-height: 1.65;
  }

  .delivery-panel li::before {
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 8px;
    height: 2px;
    content: '';
    background: var(--success);
    box-shadow:
      0 0 7px
        rgba(121, 230, 167, 0.65);
  }

  .planned-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 35px;
  }

  .planned-card {
    display: flex;
    align-items: flex-start;
    gap: 17px;
    padding: 23px;
  }

  .planned-card > span {
    color: #e4bc70;
    font-family: monospace;
    font-size: 0.68rem;
  }

  .planned-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .confidentiality-panel {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    margin: clamp(34px, 5vw, 60px);
    padding: 22px;
    border: 1px solid
      rgba(121, 174, 230, 0.15);
    border-radius: 18px;
    background:
      rgba(121, 174, 230, 0.045);
  }

  .notice-light {
    margin-top: 4px;
    background: #79aee6;
    box-shadow: 0 0 10px #79aee6;
  }

  .confidentiality-panel p {
    margin: 0 0 7px;
    color: #79aee6;
    font-family: monospace;
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  .confidentiality-panel strong {
    color: #aebac3;
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .case-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 30px
      clamp(38px, 6vw, 72px);
  }

  .case-footer p,
  .case-footer strong {
    display: block;
  }

  .case-footer p {
    margin: 0 0 6px;
    color: #777f83;
    font-family: monospace;
    font-size: 0.64rem;
    letter-spacing: 0.12em;
  }

  .case-footer a {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--success);
    font-weight: 750;
  }

  @keyframes scan {
    from {
      top: 8%;
    }

    to {
      top: 92%;
    }
